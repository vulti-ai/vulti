{
	"name": "vulti",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"npm run dev:core\" \"npm run dev:hub\"",
		"dev:core": "cd vulti-core && ./scripts/install.sh && vulti gateway web",
		"dev:hub": "cd vulti-hub && npm install && npm run dev",
		"build": "npm run build:hub",
		"build:hub": "cd vulti-hub && npm run build",
		"tauri:dev": "cd vulti-hub && npm run tauri:dev",
		"tauri:build": "cd vulti-hub && npm run tauri:build"
	},
	"devDependencies": {
		"concurrently": "^9.1.2"
	}
}
